# AgriGuard Environment Variables
# Copy this file to .env and fill in your values

# Gemini API (Free from https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY=

# News API (Currents API key)
VITE_NEWS_API_KEY=

# Supabase (From your Supabase dashboard → Settings → API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
